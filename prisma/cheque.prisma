model Cheque {
  id            String          @id @default(uuid())
  number        String          // Cheque number
  bank          String          // Bank name
  amount        Decimal
  dueDate       DateTime
  status        String          @default("PENDING") // PENDING, CLEARED, BOUNCED, CANCELLED
  type          String          // ISSUED, RECEIVED
  customerId    String?
  customer      Customer?       @relation(fields: [customerId], references: [id])
  supplierId    String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  accountId     String?         // Which account it clears to
  account       TreasuryAccount? @relation(fields: [accountId], references: [id])
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}
