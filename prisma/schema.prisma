generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String                @id @default(uuid())
  name                 String
  ownerName            String?
  activity             String?
  address              String?
  wilaya               String?
  commune              String?
  phone                String?
  fax                  String?
  email                String?
  nif                  String?
  rc                   String?
  artImposition        String?
  nis                  String?
  bankAccount          String?
  logo                 String?
  headerText           String?
  blTemplate           String?               @default("standard")
  posBlFormat          String?               @default("A4")
  posBlColumns         String?               @default("standard")
  aiProvider           String?               @default("GEMINI")
  geminiApiKey         String?
  openaiApiKey         String?
  anthropicApiKey      String?
  whatsappToken        String?
  whatsappPhoneId      String?
  whatsappPhone        String?
  loyaltyPointsPerDa   Int                   @default(1)
  loyaltyDaPerPoint    Int                   @default(100)
  subscriptionEndsAt   DateTime?
  isBlocked            Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  yalidineApiId        String?
  yalidineApiToken     String?
  dhdApiToken          String?
  hddApiToken          String?
  ramadanMode          Boolean               @default(false)
  commissionRate       Float                 @default(0)
  commissionMode       String                @default("CATEGORY")
  taxRegime            String?               @default("G50")
  ifuRate              Float?                @default(5)
  tapRate              Float                 @default(2)
  stampTaxEnabled      Boolean               @default(true)
  posTimbreEnabled     Boolean               @default(false)
  aiModel              String?               @default("gemini-1.5-flash")
  smtpHost             String?
  smtpPort             String?
  smtpUser             String?
  smtpPass             String?
  smtpFrom             String?
  AiLog                AiLog[]
  auditLogs            AuditLog[]
  brands               Brand[]
  categories           Category[]
  customers            Customer[]
  dailyCloses          DailyClose[]
  deliveryShipments    DeliveryShipment[]
  deliveryTours        DeliveryTour[]
  driverLocations      DriverLocation[]
  expenses             Expense[]
  expenseCategories    ExpenseCategory[]
  invoices             Invoice[]
  mobileTokens         MobileRefreshToken[]
  orders               Order[]
  products             Product[]
  productReturns       ProductReturn[]
  proformas            Proforma[]
  promotions           Promotion[]
  purchaseOrders       PurchaseOrder[]
  recurringInvoices    RecurringInvoice[]
  reservations         Reservation[]
  salesOrders          SalesOrder[]
  sequenceCounters     SequenceCounter[]
  spoilages            Spoilage[]
  stockCountSessions   StockCountSession[]
  stockMovements       StockMovement[]
  stores               Store[]
  suppliers            Supplier[]
  tenantUsers          TenantUser[]
  treasuryAccounts     TreasuryAccount[]
  treasuryTransactions TreasuryTransaction[]
  truckLoads           TruckLoad[]
  users                User[]
  Cheque               Cheque[]
  Transfer             Transfer[]
  commissionPayments   SellerCommissionPayment[]
}

model Store {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  address        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  dailyCloses    DailyClose[]
  invoices       Invoice[]
  orders         Order[]
  proformas      Proforma[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  spoilages      Spoilage[]
  stockMovements StockMovement[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeProducts  StoreProduct[]
  users          User[]          @relation("UserDefaultStore")
  transfersFrom  Transfer[]      @relation("TransfersFrom")
  transfersTo    Transfer[]      @relation("TransfersTo")
}

model StoreProduct {
  id        String   @id @default(uuid())
  storeId   String
  productId String
  stock     Int      @default(0)
  minStock  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@index([storeId, stock])
}

model RecurringInvoice {
  id              String                 @id @default(uuid())
  tenantId        String
  customerId      String
  status          String                 @default("ACTIVE")
  frequency       String                 @default("MONTHLY")
  nextRunDate     DateTime
  lastRunDate     DateTime?
  subTotal        Decimal                @default(0)
  tax             Decimal                @default(0)
  total           Decimal                @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  customer        Customer               @relation(fields: [customerId], references: [id])
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items           RecurringInvoiceItem[]
  generatedOrders SalesOrder[]
}

model RecurringInvoiceItem {
  id                 String           @id @default(uuid())
  recurringInvoiceId String
  productId          String
  quantity           Int
  unitPrice          Decimal
  subTotal           Decimal
  product            Product          @relation(fields: [productId], references: [id])
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
}

model StockCountSession {
  id         String           @id @default(uuid())
  tenantId   String
  name       String
  status     String           @default("OPEN")
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  approvedAt DateTime?
  items      StockCountItem[]
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
}

model StockCountItem {
  id          String            @id @default(uuid())
  sessionId   String
  productId   String
  productName String
  expectedQty Int
  actualQty   Int               @default(0)
  difference  Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  session     StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Promotion {
  id            String    @id @default(uuid())
  tenantId      String
  name          String
  type          String    @default("NTH_ITEM_DISCOUNT")
  targetScope   String    @default("ALL")
  scopeId       String?
  discountType  String    @default("PERCENT")
  discountValue Decimal   @default(30)
  triggerQty    Int       @default(2)
  isActive      Boolean   @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
}

model User {
  id              String               @id @default(uuid())
  email           String               @unique
  name            String?
  password        String
  phone           String?
  isSuperadmin    Boolean              @default(false)
  canEdit         Boolean              @default(false)
  canDelete       Boolean              @default(false)
  role            String               @default("CASHIER")
  tenantId        String
  defaultStoreId  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deliveryTours   DeliveryTour[]
  driverLocations DriverLocation[]
  mobileTokens    MobileRefreshToken[]
  orders          Order[]
  productReturns  ProductReturn[]
  spoilages       Spoilage[]
  stockMovements  StockMovement[]
  tenantUsers        TenantUser[]
  truckLoads         TruckLoad[]
  salesOrders        SalesOrder[]              @relation("UserSalesOrders")
  commissionPayments SellerCommissionPayment[] @relation("UserCommissionPayments")
  defaultStore       Store?                    @relation("UserDefaultStore", fields: [defaultStoreId], references: [id])
  tenant             Tenant                    @relation(fields: [tenantId], references: [id])
  Transfer           Transfer[]

  @@index([tenantId])
  @@index([email])
}

model TenantUser {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Product {
  id             String                 @id @default(uuid())
  name           String
  description    String?
  price          Decimal
  cost           Decimal?
  wholesalePrice Decimal?
  dealerPrice    Decimal?
  tvaRate        Decimal                @default(19)
  isFeatured     Boolean                @default(false)
  isArchived     Boolean                @default(false)
  stock          Int                    @default(0)
  minStock       Int                    @default(0)
  categoryId     String?
  brandId        String?
  tenantId       String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  barcodes       Barcode[]
  images         Image[]
  invoiceItems   InvoiceItem[]
  orderItems     OrderItem[]
  brand          Brand?                 @relation(fields: [brandId], references: [id])
  category       Category?              @relation(fields: [categoryId], references: [id])
  tenant         Tenant                 @relation(fields: [tenantId], references: [id])
  productReturns ProductReturn[]
  proformaItems  ProformaItem[]
  purchaseItems  PurchaseOrderItem[]
  recurringItems RecurringInvoiceItem[]
  reservations   Reservation[]
  salesItems     SalesOrderItem[]
  spoilages      Spoilage[]
  stockMovements StockMovement[]
  storeProducts  StoreProduct[]
  truckLoadItems TruckLoadItem[]
  TransferItem   TransferItem[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
  @@index([tenantId, categoryId])
  @@index([tenantId, createdAt])
  @@index([name])
}

model Image {
  id        String   @id @default(uuid())
  productId String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Barcode {
  id        String   @id @default(uuid())
  value     String
  label     String?
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([value])
  @@index([productId])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  tenantId  String
  imageUrl            String?
  isArchived          Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  commissionWholesale Float     @default(0)
  commissionReseller  Float     @default(0)
  commissionRetail    Float     @default(0)
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  products            Product[]
}

model Brand {
  id        String    @id @default(uuid())
  name      String
  tenantId  String
  imageUrl            String?
  isArchived          Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  commissionWholesale Float     @default(0)
  commissionReseller  Float     @default(0)
  commissionRetail    Float     @default(0)
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  products            Product[]
}

model Customer {
  id                String             @id @default(uuid())
  name              String
  phone             String?
  email             String?
  address           String?
  city              String?
  taxId             String?
  nif               String?
  nis               String?
  artImposition     String?
  rc                String?
  rib               String?
  notes             String?
  barcode           String?            @unique
  loyaltyPoints     Int                @default(0)
  balance           Decimal            @default(0)
  tenantId          String
  clientType        String             @default("RETAIL")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  invoices          Invoice[]
  orders            Order[]
  productReturns    ProductReturn[]
  proformas         Proforma[]
  recurringInvoices RecurringInvoice[]
  reservations      Reservation[]
  salesOrders       SalesOrder[]
  tourStops         TourStop[]
  Cheque            Cheque[]

  @@index([tenantId])
  @@index([tenantId, balance])
  @@index([name])
}

model Supplier {
  id              String          @id @default(uuid())
  name            String
  contactPerson   String?
  email           String?
  phone           String?
  address         String?
  taxId           String?
  nif             String?
  nis             String?
  artImposition   String?
  rc              String?
  rib             String?
  notes           String?
  balance         Decimal         @default(0)
  withholdingRate Float           @default(0)
  tenantId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  purchaseOrders  PurchaseOrder[]
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  Cheque          Cheque[]
}

model Order {
  id            String           @id @default(uuid())
  subtotal      Decimal          @default(0)
  tvaAmount     Decimal          @default(0)
  stampTax      Decimal          @default(0)
  total         Decimal
  paidAmount    Decimal          @default(0)
  status        String           @default("COMPLETED")
  paymentMethod String           @default("CASH")
  userId        String
  customerId    String?
  tenantId      String
  storeId       String?
  accountId     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  account       TreasuryAccount? @relation(fields: [accountId], references: [id])
  customer      Customer?        @relation(fields: [customerId], references: [id])
  store         Store?           @relation(fields: [storeId], references: [id])
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
  items         OrderItem[]

  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, storeId, status, createdAt])
  @@index([tenantId, storeId, createdAt, paymentMethod])
  @@index([customerId, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal
  priceHt   Decimal @default(0)
  tvaRate   Decimal @default(0)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id                String              @id @default(uuid())
  supplierId        String
  tenantId          String
  storeId           String?
  total             Decimal
  withholdingAmount Decimal             @default(0)
  status            String              @default("PENDING")
  accountId         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  reference         String?
  imageUrl1         String?
  imageUrl2         String?
  imageUrl3         String?
  account           TreasuryAccount?    @relation(fields: [accountId], references: [id])
  store             Store?              @relation(fields: [storeId], references: [id])
  supplier          Supplier            @relation(fields: [supplierId], references: [id])
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  items             PurchaseOrderItem[]

  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  costPrice       Decimal
  tvaRate         Decimal       @default(19)
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model SalesOrder {
  id                  String            @id @default(uuid())
  tenantId            String
  storeId             String?
  customerId          String
  type                String            @default("ORDER")
  status              String            @default("DRAFT")
  receiptNumber       String?
  paymentMethod       String            @default("CASH")
  paymentStatus       String            @default("PENDING")
  amountPaid          Decimal           @default(0)
  subtotal            Decimal           @default(0)
  tvaAmount           Decimal           @default(0)
  stampTax            Decimal           @default(0)
  total               Decimal
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  recurringInvoiceId  String?
  relatedSalesOrderId String?
  proformaId          String?
  invoiceItems        InvoiceItem[]
  customer            Customer          @relation(fields: [customerId], references: [id])
  proforma            Proforma?         @relation(fields: [proformaId], references: [id])
  recurringInvoice    RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])
  store               Store?            @relation(fields: [storeId], references: [id])
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  userId              String?
  user                User?             @relation("UserSalesOrders", fields: [userId], references: [id])
  items               SalesOrderItem[]
  deliveryShipments   DeliveryShipment[]
  source              String            @default("POS") // POS, MOBILE, ECOMMERCE

  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, storeId, status, createdAt])
  @@index([proformaId])
  @@index([userId])
  @@index([tenantId, paymentStatus])
  @@index([receiptNumber])
  @@index([tenantId, source])
}

model SalesOrderItem {
  id           String     @id @default(uuid())
  salesOrderId String
  productId    String
  quantity     Int
  unitPrice    Decimal
  tvaRate      Decimal    @default(0)
  priceHt      Decimal    @default(0)
  product      Product    @relation(fields: [productId], references: [id])
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String    @id @default(uuid())
  name      String
  type      String    @default("VARIABLE")
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
}

model Expense {
  id          String           @id @default(uuid())
  description String
  amount      Decimal
  date        DateTime         @default(now())
  categoryId  String
  tenantId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  accountId   String?
  imageUrl    String?
  account     TreasuryAccount? @relation(fields: [accountId], references: [id])
  category    ExpenseCategory  @relation(fields: [categoryId], references: [id])
  tenant      Tenant           @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, categoryId, date])
}

model TreasuryAccount {
  id           String                @id @default(uuid())
  name         String
  type         String
  balance      Decimal               @default(0)
  rib          String?
  tenantId     String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  expenses     Expense[]
  orders       Order[]
  purchases    PurchaseOrder[]
  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  transactions TreasuryTransaction[]
  Cheque       Cheque[]
}

model TreasuryTransaction {
  id            String          @id @default(uuid())
  accountId     String
  type          String
  amount        Decimal
  balanceBefore Decimal
  balanceAfter  Decimal
  source        String
  referenceId   String?
  description   String?
  imageUrl      String?
  date          DateTime        @default(now())
  tenantId      String
  createdAt     DateTime        @default(now())
  account       TreasuryAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, accountId, createdAt])
  @@index([referenceId, source])
  @@index([tenantId, createdAt])
}

model Spoilage {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  reason    String?
  quantity  Int
  productId String
  userId    String
  tenantId  String
  storeId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store?   @relation(fields: [storeId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model DailyClose {
  id              String   @id @default(uuid())
  tenantId        String
  storeId         String?
  date            DateTime @default(now())
  periodStart     DateTime
  periodEnd       DateTime
  totalRevenue    Decimal  @default(0)
  cashRevenue     Decimal  @default(0)
  transferRevenue Decimal  @default(0)
  checkRevenue    Decimal  @default(0)
  termRevenue     Decimal  @default(0)
  totalExpenses   Decimal  @default(0)
  netCash         Decimal  @default(0)
  ordersCount     Int      @default(0)
  salesCount      Int      @default(0)
  notes           String?
  closedByUserId  String?
  createdAt       DateTime @default(now())
  store           Store?   @relation(fields: [storeId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id          String   @id @default(uuid())
  productId   String
  type        String
  quantity    Int
  stockBefore Int
  stockAfter  Int
  referenceId String?
  reason      String?
  userId      String?
  tenantId    String
  storeId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store       Store?   @relation(fields: [storeId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
}

model Reservation {
  id            String    @id @default(uuid())
  tenantId      String
  productId     String
  customerId    String?
  quantity      Float     @default(1)
  depositAmount Float     @default(0)
  totalAmount   Float     @default(0)
  status        String    @default("PENDING")
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer? @relation(fields: [customerId], references: [id])
  product       Product   @relation(fields: [productId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DeliveryShipment {
  id              String   @id @default(uuid())
  tenantId        String
  salesOrderId    String?
  provider        String
  trackingCode    String?
  providerRef     String?
  customerName    String
  customerPhone   String
  customerAddress String
  wilaya          String
  commune         String?
  weight          Float    @default(0.5)
  codAmount       Float    @default(0)
  deliveryCost    Float    @default(0)
  status          String   @default("PENDING")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder      SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model LicenseRequest {
  id          String    @id @default(uuid())
  companyName String
  ownerName   String
  phone       String
  email       String
  address     String?
  wilaya      String?
  machineId   String
  ipAddress   String?
  plan        String    @default("lifetime")
  status      String    @default("PENDING")
  licenseKey  String?
  notes       String?
  createdAt   DateTime  @default(now())
  approvedAt  DateTime?

  @@index([status])
  @@index([machineId])
  @@index([createdAt])
}

model SequenceCounter {
  id        String   @id @default(uuid())
  tenantId  String
  prefix    String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, prefix, year])
  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  userName    String?
  action      String
  entity      String
  entityId    String?
  description String?
  before      String?
  after       String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, createdAt])
  @@index([userId])
}

model MobileRefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  tenantId   String
  deviceName String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model DeliveryTour {
  id          String     @id @default(uuid())
  tenantId    String
  driverId    String
  name        String?
  date        DateTime   @default(now())
  status      String     @default("PLANNED")
  startedAt   DateTime?
  completedAt DateTime?
  totalKm     Float      @default(0)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  driver      User       @relation(fields: [driverId], references: [id])
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stops       TourStop[]
  truckLoad   TruckLoad?

  @@index([tenantId])
  @@index([tenantId, driverId])
  @@index([tenantId, date])
  @@index([tenantId, status])
}

model TourStop {
  id            String       @id @default(uuid())
  tourId        String
  customerId    String
  sortOrder     Int          @default(0)
  status        String       @default("PENDING")
  latitude      Float?
  longitude     Float?
  arrivedAt     DateTime?
  completedAt   DateTime?
  signatureUrl  String?
  photoUrl      String?
  notes         String?
  salesOrderId  String?
  paymentAmount Float        @default(0)
  paymentMethod String?
  returnAmount  Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  customer      Customer     @relation(fields: [customerId], references: [id])
  tour          DeliveryTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@index([customerId])
  @@index([tourId, sortOrder])
}

model TruckLoad {
  id         String          @id @default(uuid())
  tenantId   String
  tourId     String          @unique
  driverId   String
  status     String          @default("LOADING")
  loadedAt   DateTime?
  returnedAt DateTime?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  driver     User            @relation(fields: [driverId], references: [id])
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tour       DeliveryTour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
  items      TruckLoadItem[]

  @@index([tenantId])
  @@index([tourId])
}

model TruckLoadItem {
  id           String    @id @default(uuid())
  truckLoadId  String
  productId    String
  qtyLoaded    Int
  qtySold      Int       @default(0)
  qtyReturned  Int       @default(0)
  qtyRemaining Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  product      Product   @relation(fields: [productId], references: [id])
  truckLoad    TruckLoad @relation(fields: [truckLoadId], references: [id], onDelete: Cascade)

  @@index([truckLoadId])
  @@index([productId])
}

model ProductReturn {
  id          String   @id @default(uuid())
  tenantId    String
  tourStopId  String?
  customerId  String
  driverId    String
  productId   String
  quantity    Int
  unitPrice   Float    @default(0)
  totalAmount Float    @default(0)
  reason      String
  photoUrl    String?
  notes       String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id])
  driver      User     @relation(fields: [driverId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, createdAt])
}

model DriverLocation {
  id        String   @id @default(uuid())
  tenantId  String
  driverId  String
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  accuracy  Float?
  source    String   @default("PHONE")
  tourId    String?
  createdAt DateTime @default(now())
  driver    User     @relation(fields: [driverId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, driverId])
  @@index([tenantId, createdAt])
  @@index([driverId, createdAt])
}

model Proforma {
  id             String         @id @default(uuid())
  tenantId       String
  storeId        String?
  customerId     String
  proformaNumber String
  status         String         @default("DRAFT")
  subtotal       Decimal        @default(0)
  tvaAmount      Decimal        @default(0)
  stampTax       Decimal        @default(0)
  total          Decimal
  validUntil     DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  customer       Customer       @relation(fields: [customerId], references: [id])
  store          Store?         @relation(fields: [storeId], references: [id])
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items          ProformaItem[]
  salesOrders    SalesOrder[]

  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([proformaNumber])
}

model ProformaItem {
  id                String   @id @default(uuid())
  proformaId        String
  productId         String
  quantity          Int
  quantityDelivered Int      @default(0)
  unitPrice         Decimal
  tvaRate           Decimal  @default(0)
  priceHt           Decimal  @default(0)
  product           Product  @relation(fields: [productId], references: [id])
  proforma          Proforma @relation(fields: [proformaId], references: [id], onDelete: Cascade)

  @@index([proformaId])
  @@index([productId])
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  storeId       String?
  customerId    String
  invoiceNumber String
  status        String        @default("DRAFT")
  subtotal      Decimal       @default(0)
  tvaAmount     Decimal       @default(0)
  stampTax      Decimal       @default(0)
  total         Decimal
  amountPaid    Decimal       @default(0)
  paymentStatus String        @default("PENDING")
  paymentMethod String?
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customer      Customer      @relation(fields: [customerId], references: [id])
  store         Store?        @relation(fields: [storeId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]

  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([invoiceNumber])
  @@index([tenantId, paymentStatus])
}

model InvoiceItem {
  id           String     @id @default(uuid())
  invoiceId    String
  salesOrderId String
  productId    String
  quantity     Int
  unitPrice    Decimal
  tvaRate      Decimal    @default(0)
  priceHt      Decimal    @default(0)
  invoice      Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@index([invoiceId])
  @@index([salesOrderId])
  @@index([productId])
}

model AiLog {
  id        String   @id @default(uuid())
  tenantId  String
  provider  String
  model     String?
  prompt    String
  response  String
  createdAt DateTime @default(now())
  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId])
  @@index([tenantId, provider])
}

model Transfer {
  id          String         @id @default(uuid())
  reference   String
  fromStoreId String
  toStoreId   String
  status      String         @default("PENDING") // PENDING, SENT, COMPLETED, CANCELLED
  tenantId    String
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sentAt      DateTime?
  completedAt DateTime?
  notes       String?
  fromStore   Store          @relation("TransfersFrom", fields: [fromStoreId], references: [id])
  toStore     Store          @relation("TransfersTo", fields: [toStoreId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  createdBy   User           @relation(fields: [createdById], references: [id])
  items       TransferItem[]

  @@index([tenantId])
  @@index([fromStoreId])
  @@index([toStoreId])
}

model TransferItem {
  id         String   @id @default(uuid())
  transferId String
  productId  String
  quantity   Int
  product    Product  @relation(fields: [productId], references: [id])
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([productId])
}

model Cheque {
  id         String           @id @default(uuid())
  number     String // Cheque number
  bank       String // Bank name
  amount     Decimal
  dueDate    DateTime
  status     String           @default("PENDING") // PENDING, CLEARED, BOUNCED, CANCELLED
  type       String // ISSUED, RECEIVED
  customerId String?
  customer   Customer?        @relation(fields: [customerId], references: [id])
  supplierId String?
  supplier   Supplier?        @relation(fields: [supplierId], references: [id])
  accountId  String? // Which account it clears to
  account    TreasuryAccount? @relation(fields: [accountId], references: [id])
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate, status])
}

model SellerCommissionPayment {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  amount    Decimal
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation("UserCommissionPayments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}
